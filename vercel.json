{
  "version": 2,
  "buildCommand": "pnpm run typecheck && pnpm --filter @workspace/interlink --filter @workspace/api-server run build",
  "outputDirectory": "artifacts/interlink/dist",
  "installCommand": "pnpm install",
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
